rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function getUserData() { 
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; 
    }
    function hasRole(role) { 
      return isSignedIn() && getUserData().role == role; 
    }
    function isAdmin() { 
      return hasRole('admin'); 
    }
    function isShopManager(shopId) {
      return hasRole('shop') && getUserData().shopId == shopId;
    }
    function isOwner(userId) { 
      return isSignedIn() && request.auth.uid == userId; 
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      
      allow update: if isAdmin() || (
        isOwner(userId) && 
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'shopId']))
      );
      
      allow delete: if isAdmin();
    }

    // --- Shops Collection ---
    match /shops/{shopId} {
      allow read: if true;
      allow create: if isAdmin();
      
      allow update: if isAdmin() || isShopManager(shopId);
      
      allow delete: if isAdmin();
    }

    // --- Products Collection ---
    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() || isShopManager(request.resource.data.shopId);
      
      allow update: if isAdmin() || isShopManager(resource.data.shopId);
      
      allow delete: if isAdmin() || isShopManager(resource.data.shopId);
    }

    // --- Employees Collection ---
    match /employees/{employeeId} {
      allow read: if isAdmin() || (
        isSignedIn() && (
          (resource != null && isShopManager(resource.data.shopId)) ||
          (request.resource != null && isShopManager(request.resource.data.shopId))
        )
      );
      allow write: if isAdmin() || (
        isSignedIn() && (
          (resource != null && isShopManager(resource.data.shopId)) ||
          (request.resource != null && isShopManager(request.resource.data.shopId))
        )
      );
    }
    
    // --- Schedules Collection ---
    match /schedules/{scheduleId} {
      allow read, write: if isAdmin() || (
        isSignedIn() && (
          (resource != null && isShopManager(resource.data.shopId)) ||
          (request.resource != null && isShopManager(request.resource.data.shopId))
        )
      );
    }
  }
}
